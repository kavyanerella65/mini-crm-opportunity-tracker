# Port the Express server listens on
PORT=5000

# MongoDB connection string (MongoDB Atlas or any hosted/local MongoDB instance)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/mini-crm?retryWrites=true&w=majority

# Long, random secret used to sign/verify JWTs — generate your own, never reuse this
JWT_SECRET=replace_this_with_a_long_random_string

# Token lifetime (assignment requires ~2 hours)
JWT_EXPIRES_IN=2h

# Comma-separated list of allowed frontend origins for CORS
CLIENT_URL=http://localhost:5173

# development | production | test
NODE_ENV=development
